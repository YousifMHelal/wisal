// Wisal Command Center — Prisma Schema
// Full schema built in Phase 1 (P1-1). This stub allows the client to generate
// so TypeScript can resolve @/lib/generated/prisma during Phase 0.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users & Auth ─────────────────────────────────────────────────────────────

enum UserRole {
  OPERATOR
  SUPERVISOR
  COMPLIANCE
  EXECUTIVE
  PLATFORM_ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(OPERATOR)
  clusterId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
